# ────────────────────────────────────────────────
# Firebase 웹 설정
# Firebase 콘솔 → 프로젝트 설정 → 내 앱(웹) 에서 복사
# (웹 config는 비밀이 아니지만 환경별 분리를 위해 .env로 관리)
# ────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

# 로컬 Firebase 에뮬레이터 사용 시 "true" (실제 클라우드 대신)
VITE_USE_EMULATOR=false

# ────────────────────────────────────────────────
# Cloudflare Worker (이미지 업로드 중계)
# ⚠️ 웹앱(client)에서 쓰지 않음. Worker 시크릿으로만 설정.
#    wrangler secret put CLOUDFLARE_IMAGES_TOKEN
# ────────────────────────────────────────────────
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_IMAGES_TOKEN=
